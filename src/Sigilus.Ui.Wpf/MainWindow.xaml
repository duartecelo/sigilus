<Window x:Class="Sigilus.Ui.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:conv="clr-namespace:Sigilus.Ui.Wpf.Converters"
        Title="Sigilus 2.0"
        Height="820" Width="1280"
        MinHeight="520" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
        ui:TitleBar.IsIconVisible="False"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        KeyDown="OnWindowKeyDown">

    <Window.Resources>
        <conv:FileNameConverter x:Key="FileNameConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- conteúdo -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- NAVIGATION + CONTEÚDO -->
        <ui:NavigationView x:Name="Nav" Grid.Row="0"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="False"
                           PaneDisplayMode="Left"
                           OpenPaneLength="220"
                           CompactPaneLength="52"
                           IsPaneToggleButtonVisible="True"
                           SelectionChanged="OnNavSelectionChanged">
            <ui:NavigationView.PaneFooter>
                <Button x:Name="ThemeToggleButton" Click="OnThemeToggleClick"
                        ToolTip="Alternar tema (Ctrl+T)"
                        Background="Transparent" BorderThickness="0"
                        Margin="4,0,4,8" Padding="14,10" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ThemeIcon" Text="&#xE706;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="16" Margin="0,0,14,0"/>
                        <TextBlock x:Name="ThemeLabel" Text="Tema claro" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ui:NavigationView.PaneFooter>
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="NavDocument" Content="Documento" IsSelected="True">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8A5;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="NavSettings" Content="Configurações">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE713;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <Grid>
                <!-- ========== PÁGINA DOCUMENTO ========== -->
                <Grid x:Name="DocumentPage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- cabeçalho do doc -->
                        <RowDefinition Height="*"/>      <!-- viewer -->
                        <RowDefinition Height="Auto"/>   <!-- nav + zoom -->
                    </Grid.RowDefinitions>

                    <!-- card "Documento atual" -->
                    <Border Grid.Row="0" Margin="24,16,24,8"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="8" Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="DocTitle" Text="Nenhum documento aberto" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DocSubtitle" Text="Clique em Abrir para começar"
                                           FontSize="12" Opacity="0.7" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="OpenButton" Click="OnOpenClick" Margin="0,0,6,0" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE8E5;" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="Abrir"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="DetectButton" Click="OnDetectClick" Margin="0,0,6,0" Padding="10,6"
                                        Style="{DynamicResource AccentButtonStyle}" IsEnabled="False">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE721;" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="Detectar"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CancelButton" Click="OnCancelClick" Margin="0,0,6,0" Padding="10,6" IsEnabled="False"
                                        ToolTip="Cancelar análise">
                                    <ui:FontIcon Glyph="&#xE711;" FontSize="13"/>
                                </Button>
                                <Button x:Name="SaveButton" Click="OnRedactClick" Padding="10,6" IsEnabled="False">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE74E;" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="Salvar"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- viewer -->
                    <Border Grid.Row="1" Margin="24,4,24,4"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PageScroller"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="OnScrollerPreviewMouseWheel"
                                      SizeChanged="OnScrollerSizeChanged"
                                      Background="Transparent">
                            <Grid x:Name="PageGrid" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.LayoutTransform>
                                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.LayoutTransform>
                                <Image x:Name="PageImage" Stretch="None" SnapsToDevicePixels="True"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <!-- nav + zoom -->
                    <Grid Grid.Row="2" Margin="24,8,24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PrevButton" Click="OnPrevPageClick" ToolTip="Página anterior (PgUp ou ←)"
                                    Width="36" Height="32" Padding="0">
                                <ui:FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <TextBlock x:Name="PageIndicator" Text="—" VerticalAlignment="Center"
                                       MinWidth="100" TextAlignment="Center" FontSize="13"/>
                            <Button x:Name="NextButton" Click="OnNextPageClick" ToolTip="Próxima página (PgDn ou →)"
                                    Width="36" Height="32" Padding="0">
                                <ui:FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="OnFitClick" Margin="0,0,6,0" ToolTip="Ajustar à janela" Height="32" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE9A6;" FontSize="13" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ajustar"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnZoomOutClick" ToolTip="Diminuir (Ctrl+−)" Width="32" Height="32" Padding="0">
                                <ui:FontIcon Glyph="&#xE949;" FontSize="13"/>
                            </Button>
                            <TextBlock x:Name="ZoomIndicator" Text="100%" VerticalAlignment="Center"
                                       MinWidth="48" TextAlignment="Center" FontSize="13"/>
                            <Button Click="OnZoomInClick" ToolTip="Aumentar (Ctrl++)" Width="32" Height="32" Padding="0">
                                <ui:FontIcon Glyph="&#xE948;" FontSize="13"/>
                            </Button>
                            <Button Click="OnZoomResetClick" Margin="6,0,0,0" ToolTip="Tamanho original (Ctrl+0)" Height="32" Padding="10,0">
                                <TextBlock Text="1:1" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ========== PÁGINA CONFIGURAÇÕES ========== -->
                <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24,32,32" MaxWidth="780" HorizontalAlignment="Left">
                        <TextBlock Text="Configurações" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>

                        <!-- Aparência -->
                        <TextBlock Text="Aparência" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Tema" FontWeight="SemiBold"/>
                                        <TextBlock Text="Escolha entre claro, escuro ou seguir o sistema." Opacity="0.65" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Width="160" SelectionChanged="OnThemeComboChanged">
                                        <ComboBoxItem Content="Sistema" Tag="System"/>
                                        <ComboBoxItem Content="Claro" Tag="Light"/>
                                        <ComboBoxItem Content="Escuro" Tag="Dark" IsSelected="True"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Pseudonimização -->
                        <TextBlock Text="Pseudonimização" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Substituir dados sensíveis por pseudônimos" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" Opacity="0.65" Margin="0,2,0,0">
                                            Quando ativo, valores como CPF, CNPJ, nomes e endereços são substituídos por
                                            equivalentes fictícios (por exemplo, "Fulano" no lugar de "João da Silva"). Caso
                                            contrário, são cobertos com uma tarja preta.
                                        </TextBlock>
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="PseudonymizeToggle" IsOn="True"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Inteligência artificial -->
                        <TextBlock Text="Inteligência artificial" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <!-- IA rápida (NER) -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE945;" FontSize="16" Margin="0,0,8,0"
                                                         Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                                            <TextBlock Text="IA rápida (NER jurídico)" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" Opacity="0.65" Margin="0,4,0,0">
                                            Modelo neural pequeno especializado em textos jurídicos brasileiros (LeNER-Br).
                                            Detecta nomes próprios, organizações e locais em poucos segundos por página.
                                            Roda em qualquer computador, inclusive sem placa de vídeo. Requer ~110 MB em
                                            "models/".
                                        </TextBlock>
                                        <TextBlock x:Name="NerStatusText" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   FontSize="12" Margin="0,8,0,0"
                                                   Text="Estado: verificando..."/>
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="NerToggle" IsOn="False"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Toggled="OnNerToggled"/>
                                </Grid>
                                <Button Content="Baixar / atualizar NER…" Click="OnOpenAssetsManagerClick"
                                        Margin="0,12,0,0" Padding="10,6" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- IA inteligente (LLM) -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE99A;" FontSize="16" Margin="0,0,8,0"
                                                         Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                                            <TextBlock Text="IA inteligente (LLM local)" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" Opacity="0.65" Margin="0,4,0,0">
                                            Modelo de linguagem completo (Gemma 3 / Qwen 2.5 / Llama / Phi) rodando
                                            localmente via llama.cpp. Mais lento (segundos a minutos por página,
                                            dependendo do computador), porém capta dados sensíveis em qualquer parte do
                                            texto, mesmo sem padrão fixo. Funciona sem internet e sem placa de vídeo —
                                            apenas requer alguns gigabytes livres na pasta "models/llm/".
                                        </TextBlock>
                                        <TextBlock x:Name="LlmStatusText" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   FontSize="12" Margin="0,8,0,0"
                                                   Text="Estado: verificando..."/>
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="LlmToggle" IsOn="False"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Toggled="OnLlmToggled"/>
                                </Grid>

                                <!-- Seleção do modelo -->
                                <StackPanel Margin="0,16,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Modelo:" VerticalAlignment="Center" Margin="0,0,12,0"
                                               Opacity="0.85"/>
                                    <ComboBox x:Name="LlmModelCombo" MinWidth="320"
                                              SelectionChanged="OnLlmModelChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <Binding Converter="{StaticResource FileNameConverter}"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Content="Atualizar lista" Click="OnLlmRefreshClick"
                                            Margin="8,0,0,0" Padding="10,6">
                                        <Button.ToolTip>Atualiza a lista após adicionar arquivos .gguf em models/llm/.</Button.ToolTip>
                                    </Button>
                                    <Button Content="Baixar / gerenciar…" Click="OnOpenAssetsManagerClick"
                                            Margin="8,0,0,0" Padding="10,6"
                                            Style="{DynamicResource AccentButtonStyle}">
                                        <Button.ToolTip>Abre o gerenciador para baixar OCR, NER e LLMs.</Button.ToolTip>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OCR -->
                        <TextBlock Text="Reconhecimento óptico (OCR)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Estado do OCR" FontWeight="SemiBold"/>
                                <TextBlock x:Name="OcrStatusText" Opacity="0.65" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Text="Verificando..."/>
                                <TextBlock Opacity="0.5" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="O OCR é ativado automaticamente quando a pasta 'tessdata' (com por.traineddata) está disponível ao lado do executável."/>
                                <Button Content="Baixar / atualizar OCR…" Click="OnOpenAssetsManagerClick"
                                        Margin="0,12,0,0" Padding="10,6" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Sobre -->
                        <TextBlock Text="Sobre" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="20,16">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Sigilus 2.0"/>
                                <TextBlock Opacity="0.65" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Text="Redator destrutivo de PDFs jurídicos com OCR e pseudonimização determinística."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </ui:NavigationView>

        <!-- STATUS BAR -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="DetectProgress" Minimum="0" Maximum="100" Value="0"
                                 Width="180" Height="6" Margin="0,0,12,0"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed"/>
                    <TextBlock x:Name="StatusText" Text="Pronto" FontSize="12" VerticalAlignment="Center" Opacity="0.85"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusOcrChip" Text="OCR" FontSize="11" Margin="0,0,12,0"
                               Opacity="0.6" VerticalAlignment="Center"
                               ToolTip="OCR (reconhecimento de texto em páginas escaneadas)"/>
                    <TextBlock x:Name="StatusNerChip" Text="NER" FontSize="11" Margin="0,0,12,0"
                               Opacity="0.6" VerticalAlignment="Center"
                               ToolTip="IA rápida (LeNER-Br): detecta nomes e endereços por modelo neural pequeno"/>
                    <TextBlock x:Name="StatusLlmChip" Text="LLM" FontSize="11" Opacity="0.6" VerticalAlignment="Center"
                               ToolTip="IA inteligente (Llama/Gemma local): análise completa do texto"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
