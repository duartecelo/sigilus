<Window x:Class="Sigilus.Ui.Wpf.DownloadModelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Baixar modelo de IA"
        Width="640" Height="540"
        MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        ui:WindowHelper.UseModernWindowStyle="True"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Baixar modelo de IA local" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,0">
                Escolha um modelo abaixo e clique em Baixar. Os modelos vêm do Hugging Face (servidor público —
                não precisa de conta). Após o download, o arquivo fica em <Run FontWeight="SemiBold">models\llm\</Run>
                e aparece automaticamente na lista de modelos do Sigilus.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="6" Padding="4">
            <ListBox x:Name="ModelList" BorderThickness="0" Background="Transparent"
                     SelectionChanged="OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text=" · " Opacity="0.5"/>
                                <TextBlock Text="{Binding SizeHuman}" Opacity="0.7"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.7" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Progresso -->
        <Border Grid.Row="2" Margin="0,14,0,0" Padding="12,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="6">
            <StackPanel>
                <Grid>
                    <TextBlock x:Name="ProgressTitle" Text="Selecione um modelo." FontSize="12"/>
                    <TextBlock x:Name="ProgressEta" HorizontalAlignment="Right" FontSize="12" Opacity="0.7"/>
                </Grid>
                <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Botões -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="Fechar" Click="OnCancelClick" MinWidth="100" Padding="10,6"/>
            <Button x:Name="DownloadButton" Content="Baixar selecionado" Click="OnDownloadClick"
                    Style="{DynamicResource AccentButtonStyle}" MinWidth="160" Margin="8,0,0,0"
                    Padding="10,6" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
